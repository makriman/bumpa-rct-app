{
	admin off
	log default {
		output stdout
		format filter {
			request>uri query {
				replace hub.verify_token REDACTED
			}
			wrap json
		}
		level INFO
		exclude http.log.access
	}
	servers {
		# Cloudflare publishes these origin ranges at the two URLs below. Keep the
		# exact set covered by the production contract whenever Cloudflare changes it.
		# https://www.cloudflare.com/ips-v4/ https://www.cloudflare.com/ips-v6/
		trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
		trusted_proxies_strict
		client_ip_headers CF-Connecting-IP
	}
}

(security_headers) {
	header {
		-Server
		-X-Powered-By
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		Cross-Origin-Opener-Policy "same-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}
}

(non_document_csp) {
	header Content-Security-Policy "default-src 'none'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; form-action 'none'"
}

(trusted_client_ip_headers) {
	# Never append a browser-controlled forwarding chain. {client_ip} is parsed
	# from CF-Connecting-IP only for an official Cloudflare peer and otherwise
	# falls back to the direct socket peer. The private header is overwritten at
	# this sole public ingress before the Next.js BFF is allowed to use it.
	header_up X-Forwarded-For {client_ip}
	header_up X-Real-IP {client_ip}
	header_up X-Bumpa-Client-IP {client_ip}
	header_up -CF-Connecting-IP
}

(web_proxy) {
	import security_headers
	# Next owns document CSP because only its renderer can apply the matching
	# per-request nonce. This fail-closed default applies only when the upstream
	# omits CSP (for example, a health response or an upstream error).
	header ?Content-Security-Policy "default-src 'none'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; form-action 'none'"
	encode zstd gzip
	reverse_proxy {args[0]}:3000 {
		import trusted_client_ip_headers
		# Do not allow a client-supplied policy or nonce to reach Next. Middleware
		# creates and overwrites both again before rendering as defense in depth.
		header_up -Content-Security-Policy
		header_up -Content-Security-Policy-Report-Only
		header_up -X-Nonce
		health_uri /api/health
		health_interval 30s
	}
}

{$CADDY_SITE_SCHEME:http}://{$APP_DOMAIN:bumpabestie.localhost} {
	@legacyAdminRoot path /admin
	redir @legacyAdminRoot {$CADDY_SITE_SCHEME:http}://{$ADMIN_DOMAIN:admin.bumpabestie.localhost}/ 308
	@legacyAdminErrors path /admin/errors
	redir @legacyAdminErrors {$CADDY_SITE_SCHEME:http}://{$ADMIN_DOMAIN:admin.bumpabestie.localhost}/failures 308
	@legacyAdminProviders path /admin/providers
	redir @legacyAdminProviders {$CADDY_SITE_SCHEME:http}://{$ADMIN_DOMAIN:admin.bumpabestie.localhost}/provider-failures 308
	@legacyAdminSync path /admin/sync
	redir @legacyAdminSync {$CADDY_SITE_SCHEME:http}://{$ADMIN_DOMAIN:admin.bumpabestie.localhost}/sync-runs 308
	@legacyAdminUsers path /admin/users
	redir @legacyAdminUsers {$CADDY_SITE_SCHEME:http}://{$ADMIN_DOMAIN:admin.bumpabestie.localhost}/administrators 308
	@legacyAdmin path_regexp legacyAdmin ^/admin/(.*)$
	redir @legacyAdmin {$CADDY_SITE_SCHEME:http}://{$ADMIN_DOMAIN:admin.bumpabestie.localhost}/{re.legacyAdmin.1} 308
	@legacyResearchRoot path /research
	redir @legacyResearchRoot {$CADDY_SITE_SCHEME:http}://{$RESEARCH_DOMAIN:research.bumpabestie.localhost}/ 308
	@legacyResearch path_regexp legacyResearch ^/research/(.*)$
	redir @legacyResearch {$CADDY_SITE_SCHEME:http}://{$RESEARCH_DOMAIN:research.bumpabestie.localhost}/{re.legacyResearch.1} 308
	@legacyResearchConsent path /research-consent
	redir @legacyResearchConsent {$CADDY_SITE_SCHEME:http}://{$RESEARCH_DOMAIN:research.bumpabestie.localhost}/consent 308
	request_header X-Bumpa-Surface public
	import web_proxy web
}

{$CADDY_SITE_SCHEME:http}://{$WWW_DOMAIN:www.bumpabestie.localhost} {
	import security_headers
	import non_document_csp
	redir {$CADDY_SITE_SCHEME:http}://{$APP_DOMAIN:bumpabestie.localhost}{uri} 308
}

{$CADDY_SITE_SCHEME:http}://{$ADMIN_DOMAIN:admin.bumpabestie.localhost} {
	request_header X-Bumpa-Surface admin
	import web_proxy admin-web
}

{$CADDY_SITE_SCHEME:http}://{$RESEARCH_DOMAIN:research.bumpabestie.localhost} {
	request_header X-Bumpa-Surface research
	import web_proxy research-web
}

{$CADDY_SITE_SCHEME:http}://{$API_DOMAIN:api.bumpabestie.localhost} {
	import security_headers
	import non_document_csp
	encode zstd gzip
	request_body {
		max_size 10MB
	}
	reverse_proxy api:8000 {
		import trusted_client_ip_headers
		# Keep durable PostgreSQL-backed webhook ingress routable while the
		# asynchronous wake-up layer is degraded. Release gates still probe the
		# stricter /health/ready endpoint directly.
		health_uri /health/live
		health_interval 30s
	}
}
