{
	admin off
	log default {
		output stdout
		format filter {
			request>uri query {
				replace hub.verify_token REDACTED
			}
			wrap json
		}
		level INFO
		exclude http.log.access
	}
	servers {
		trusted_proxies static private_ranges
		client_ip_headers X-Forwarded-For X-Real-IP
	}
}

(security_headers) {
	header {
		-Server
		-X-Powered-By
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		Cross-Origin-Opener-Policy "same-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}
}

(non_document_csp) {
	header Content-Security-Policy "default-src 'none'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; form-action 'none'"
}

(web_proxy) {
	import security_headers
	# Next owns document CSP because only its renderer can apply the matching
	# per-request nonce. This fail-closed default applies only when the upstream
	# omits CSP (for example, a health response or an upstream error).
	header ?Content-Security-Policy "default-src 'none'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; form-action 'none'"
	encode zstd gzip
	reverse_proxy web:3000 {
		# Do not allow a client-supplied policy or nonce to reach Next. Middleware
		# creates and overwrites both again before rendering as defense in depth.
		header_up -Content-Security-Policy
		header_up -Content-Security-Policy-Report-Only
		header_up -X-Nonce
		health_uri /api/health
		health_interval 30s
	}
}

{$CADDY_SITE_SCHEME:http}://{$APP_DOMAIN:bumpabestie.localhost} {
	request_header X-Bumpa-Surface public
	import web_proxy
}

{$CADDY_SITE_SCHEME:http}://{$WWW_DOMAIN:www.bumpabestie.localhost} {
	import security_headers
	import non_document_csp
	redir {$CADDY_SITE_SCHEME:http}://{$APP_DOMAIN:bumpabestie.localhost}{uri} 308
}

{$CADDY_SITE_SCHEME:http}://{$ADMIN_DOMAIN:admin.bumpabestie.localhost} {
	request_header X-Bumpa-Surface admin
	import web_proxy
}

{$CADDY_SITE_SCHEME:http}://{$RESEARCH_DOMAIN:research.bumpabestie.localhost} {
	request_header X-Bumpa-Surface research
	import web_proxy
}

{$CADDY_SITE_SCHEME:http}://{$API_DOMAIN:api.bumpabestie.localhost} {
	import security_headers
	import non_document_csp
	encode zstd gzip
	request_body {
		max_size 10MB
	}
	reverse_proxy api:8000 {
		# Keep durable PostgreSQL-backed webhook ingress routable while the
		# asynchronous wake-up layer is degraded. Release gates still probe the
		# stricter /health/ready endpoint directly.
		health_uri /health/live
		health_interval 30s
	}
}
