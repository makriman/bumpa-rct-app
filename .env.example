# Copy to .env for local development. Never put real credentials in this file.
APP_ENV=local
APP_NAME=BumpaBestie
APP_DOMAIN=bumpabestie.localhost
WWW_DOMAIN=www.bumpabestie.localhost
ADMIN_DOMAIN=admin.bumpabestie.localhost
RESEARCH_DOMAIN=research.bumpabestie.localhost
API_DOMAIN=api.bumpabestie.localhost
PUBLIC_ORIGIN=http://bumpabestie.localhost:8080
ADMIN_ORIGIN=http://admin.bumpabestie.localhost:8080
RESEARCH_ORIGIN=http://research.bumpabestie.localhost:8080
API_ORIGIN=http://api.bumpabestie.localhost:8080
CADDY_SITE_SCHEME=http
CADDY_BIND_ADDRESS=127.0.0.1
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
NEXT_PUBLIC_APP_URL=http://bumpabestie.localhost:8080
NEXT_PUBLIC_API_BASE_URL=http://api.bumpabestie.localhost:8080
NEXT_PUBLIC_DEMO_MODE=true
API_BASE_URL=http://api:8000
TRUSTED_HOSTS=bumpabestie.localhost,admin.bumpabestie.localhost,research.bumpabestie.localhost,api.bumpabestie.localhost,api,localhost
CORS_ALLOWED_ORIGINS=http://bumpabestie.localhost:8080,http://admin.bumpabestie.localhost:8080,http://research.bumpabestie.localhost:8080
CORS_ORIGINS=["http://bumpabestie.localhost:8080","http://admin.bumpabestie.localhost:8080","http://research.bumpabestie.localhost:8080"]

# Local-only development values. Production Compose rejects these defaults.
JWT_SECRET=local-only-change-me-at-least-32-characters
OTP_SECRET=local-only-change-me-at-least-32-characters
# Explicit authentication kill switch. Production may temporarily use
# temporary_static_pin only with the scoped verifier file and an expiry.
AUTH_LOGIN_MODE=whatsapp_otp
TEMPORARY_WEB_PIN_VERIFIER=
TEMPORARY_WEB_PIN_VERIFIER_FILE=
TEMPORARY_WEB_PIN_VERIFIER_FILE_HOST=
TEMPORARY_WEB_PIN_EXPIRES_AT=
FIELD_ENCRYPTION_KEY=local-only-change-me-at-least-32-characters
FIELD_ENCRYPTION_KEY_ID=primary
# This first dual-reader artifact is production-v1-only. A later reviewed
# rollback-capability release must own any production transition to v2.
FIELD_ENCRYPTION_WRITE_VERSION=v1
FIELD_ENCRYPTION_OLD_KEYS={}
RESEARCH_PSEUDONYM_KEY=local-only-change-me-at-least-32-characters
ONBOARDING_INTEGRITY_KEY=local-only-change-me-at-least-32-characters
INTERNAL_SERVICE_TOKEN=local-only-change-me-at-least-32-characters
COOKIE_SECRET=local-only-change-me-at-least-32-characters
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=

POSTGRES_USER=bumpabestie
POSTGRES_PASSWORD=local-postgres-only
POSTGRES_DB=bumpabestie
APP_POSTGRES_PASSWORD=local-app-postgres-only
DATABASE_URL=postgresql+psycopg://bumpabestie_app:local-app-postgres-only@postgres:5432/bumpabestie
MIGRATION_DATABASE_URL=postgresql+psycopg://bumpabestie:local-postgres-only@postgres:5432/bumpabestie
SYNC_DATABASE_URL=postgresql://bumpabestie:local-postgres-only@postgres:5432/bumpabestie
REDIS_URL=redis://redis:6379/0
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
CHAT_RATE_LIMIT=12
WHATSAPP_RATE_LIMIT_WINDOW_SECONDS=60
WHATSAPP_RATE_LIMIT=12
BUMPA_SYNC_RATE_LIMIT_WINDOW_SECONDS=3600
BUMPA_SYNC_RATE_LIMIT=6
RESEARCH_REPORT_RATE_LIMIT_WINDOW_SECONDS=3600
RESEARCH_REPORT_RATE_LIMIT=10

# Credential-free local development uses deterministic provider adapters.
WHATSAPP_BACKEND=mock
AGENT_BACKEND=mock
BUMPA_BACKEND=mock
EXPOSE_LOCAL_OTP=true
LOCAL_OTP_CODE=246810
SEED_DEMO_DATA=true
MOCK_PROVIDER_LATENCY_MS=25
ASYNC_RUNTIME_ENABLED=true
ASYNC_QUEUE_NAME=default
ASYNC_QUEUE_KEY_PREFIX=bumpabestie
ASYNC_HEARTBEAT_TTL_SECONDS=45
ASYNC_POP_TIMEOUT_SECONDS=5
ASYNC_SCHEDULER_INTERVAL_SECONDS=2
ASYNC_DISPATCH_BATCH_SIZE=100
ASYNC_REDISPATCH_SECONDS=60
ASYNC_RETRY_BASE_SECONDS=5
ASYNC_RETRY_MAX_SECONDS=900
ASYNC_STALE_LOCK_SECONDS=300

# Provider variables are intentionally blank. Supply them outside git later.
META_GRAPH_VERSION=v23.0
META_APP_ID=
META_APP_SECRET=
META_APP_SECRET_FILE=
META_BUSINESS_ID=
META_WABA_ID=
META_PHONE_NUMBER_ID=
META_PHONE_NUMBER=
# Disabled by default. This verification-only lane may reply solely to signed
# inbound messages received by the exact configured WABA/phone-number pair.
META_TEST_SENDER_VERIFICATION_MODE=disabled
META_TEST_SENDER_WABA_ID=
META_TEST_SENDER_PHONE_NUMBER_ID=
META_TEST_SENDER_DISPLAY_PHONE_E164=
META_SYSTEM_USER_ACCESS_TOKEN=
META_SYSTEM_USER_ACCESS_TOKEN_FILE=
META_WEBHOOK_VERIFY_TOKEN=
META_WEBHOOK_VERIFY_TOKEN_FILE=
META_OTP_TEMPLATE_NAME=bb_otp_login
META_DAILY_INSIGHT_TEMPLATE_NAME=bb_daily_insight
META_WEEKLY_INSIGHT_TEMPLATE_NAME=bb_weekly_insight
META_TEMPLATE_LANGUAGE_CODE=en

# Proactive templates remain disabled until Meta approves both named templates.
# One body variable is required: the bounded aggregate insight summary.
PROACTIVE_INSIGHTS_ENABLED=false
DAILY_INSIGHTS_ENABLED=false
WEEKLY_INSIGHTS_ENABLED=false
DAILY_INSIGHT_LOCAL_HOUR=8
WEEKLY_INSIGHT_LOCAL_WEEKDAY=0
WEEKLY_INSIGHT_LOCAL_HOUR=8
INSIGHT_MAX_FRESHNESS_HOURS=48

# External operational alerts are disabled until a fixed HTTPS destination and
# a separate 32+ character HMAC secret file are provisioned. Never put the
# secret value or credentials in the webhook URL. The host path is copied into
# the worker's private runtime-secret volume by the one-shot initializer.
OPS_ALERTS_ENABLED=false
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_HMAC_SECRET_FILE=
OPS_ALERT_HMAC_SECRET_FILE_HOST=/dev/null
OPS_ALERT_TIMEOUT_SECONDS=10
OPS_ALERT_MAX_ATTEMPTS=3
OPS_ALERT_MAX_RESPONSE_BYTES=65536
OPS_ALERT_SCAN_LOOKBACK_HOURS=168
OPS_ALERT_SCAN_LIMIT=100
HERMES_HEALTH_ALERT_INTERVAL_MINUTES=15
AUDIT_LOG_RETENTION_DAYS=365
SYSTEM_ERROR_RETENTION_DAYS=90
OPERATIONAL_RETENTION_BATCH_SIZE=500

# Approved MCP connectors remain disabled until their OAuth clients and
# secret-file mounts are configured. Never put OAuth client secrets inline in
# production; point the *_FILE variables at a 0400 container secret instead.
MCP_GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_SECRET_FILE=
GOOGLE_OAUTH_CLIENT_SECRET_FILE_HOST=/dev/null
MCP_META_ADS_OAUTH_ENABLED=false
META_ADS_OAUTH_CLIENT_ID=
META_ADS_OAUTH_CLIENT_SECRET=
META_ADS_OAUTH_CLIENT_SECRET_FILE=
META_ADS_OAUTH_CLIENT_SECRET_FILE_HOST=/dev/null
# Hermes receives Anthropic through its dedicated secret mount, never this shared environment.
HERMES_BASE_INTERNAL_HOST=http://hermes
HERMES_PROFILE_ROOT=./.data/hermes/profiles
HERMES_PROFILE_PORT_START=8700
HERMES_PROFILE_PORT_END=8999
HERMES_CONTROL_PORT=8699
HERMES_DEFAULT_MODEL=claude-sonnet-5
HERMES_CONNECT_TIMEOUT_SECONDS=3
HERMES_READ_TIMEOUT_SECONDS=90
HERMES_MAX_RESPONSE_BYTES=262144
HERMES_MAX_CONTEXT_CHARS=12000
HERMES_CIRCUIT_FAILURE_THRESHOLD=3
HERMES_CIRCUIT_RECOVERY_SECONDS=30

# Runtime and operations
LOG_LEVEL=INFO
LOG_FORMAT=json
OTEL_SERVICE_NAME=bumpabestie
BACKUP_RETENTION_DAYS=14
BACKUP_DIR=/backups
OFFSITE_BACKUP_SCRIPT=
ARTIFACT_ROOT=/app/.data/exports
GHCR_OWNER=makriman
IMAGE_TAG=local
INFRA_IMAGE_TAG=local
DEPLOY_REF=
API_IMAGE=
WEB_IMAGE=
CADDY_IMAGE=
POSTGRES_IMAGE=
BACKUP_IMAGE=
HERMES_IMAGE=
SECRETS_DIR=./.secrets
