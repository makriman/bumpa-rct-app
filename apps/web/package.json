{
  "name": "@bumpabestie/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "api-contract:generate": "openapi-typescript ../../contracts/openapi.json --output ../../packages/web-foundation/src/generated/api-contract.ts && prettier --write ../../packages/web-foundation/src/generated/api-contract.ts",
    "brand:generate": "node scripts/generate-brand-assets.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:lighthouse": "node scripts/lighthouse-budget.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/newsreader": "5.2.10",
    "@phosphor-icons/react": "2.1.10",
    "flag-icons": "7.5.0",
    "libphonenumber-js": "1.13.8",
    "next": "15.5.20",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "chrome-launcher": "1.2.1",
    "eslint": "10.7.0",
    "eslint-config-next": "16.2.11",
    "jsdom": "29.1.1",
    "lighthouse": "13.4.1",
    "openapi-typescript": "7.13.0",
    "prettier": "3.9.6",
    "sharp": "0.35.3",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "overrides": {
    "js-yaml": "4.3.0",
    "postcss": "8.5.11"
  }
}
