APP_ENV=local
DATABASE_URL=sqlite:///./.data/bumpabestie.db
JWT_SECRET=local-only-change-me-jwt-secret-32bytes
OTP_SECRET=local-only-change-me-otp-secret
FIELD_ENCRYPTION_KEY=local-only-change-me-field-key
FIELD_ENCRYPTION_KEY_ID=primary
# Local/test code may exercise v2, but this artifact rejects v2 in production
# until a later release mechanically establishes a dual-reader rollback floor.
FIELD_ENCRYPTION_WRITE_VERSION=v1
FIELD_ENCRYPTION_OLD_KEYS={}
RESEARCH_PSEUDONYM_KEY=local-only-change-me-research-pseudonym-key
ONBOARDING_INTEGRITY_KEY=local-only-change-me-onboarding-integrity-key
SEED_DEMO_DATA=true
EXPOSE_LOCAL_OTP=true
LOCAL_OTP_CODE=246810
DEV_FIXED_OTP=246810
DEV_OTP_SINK=log
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://admin.localhost:3000,http://research.localhost:3000
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=
WHATSAPP_BACKEND=mock
BUMPA_BACKEND=mock
AGENT_BACKEND=mock
META_WEBHOOK_VERIFY_TOKEN=local-webhook-token
META_APP_SECRET=local-meta-app-secret
META_TEST_SENDER_VERIFICATION_MODE=disabled
META_TEST_SENDER_WABA_ID=
META_TEST_SENDER_PHONE_NUMBER_ID=
META_TEST_SENDER_DISPLAY_PHONE_E164=
META_DAILY_INSIGHT_TEMPLATE_NAME=bb_daily_insight
META_WEEKLY_INSIGHT_TEMPLATE_NAME=bb_weekly_insight
PROACTIVE_INSIGHTS_ENABLED=false
DAILY_INSIGHTS_ENABLED=false
WEEKLY_INSIGHTS_ENABLED=false
OPS_ALERTS_ENABLED=false
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_HMAC_SECRET_FILE=
AUDIT_LOG_RETENTION_DAYS=365
SYSTEM_ERROR_RETENTION_DAYS=90
OPERATIONAL_RETENTION_BATCH_SIZE=500
